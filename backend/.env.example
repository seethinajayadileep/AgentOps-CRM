# AgentOps CRM Backend - Environment Variables Example
# Copy this file to .env and fill in actual values

# Server
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentops_crm
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI Services
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# External Tools
FIRECRAWL_API_KEY=fc-...

# Vapi Voice Call Integration (F-008)
VAPI_ENABLED=true
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_assistant_id_here
# IMPORTANT: VAPI_PHONE_NUMBER_ID must be the UUID of your Vapi phone number resource
# Find this in your Vapi dashboard: Phone Numbers -> Click on your number -> Copy the ID
# This is NOT the actual phone number (e.g., +19802657069) but the UUID identifier
# Example format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_PHONE_NUMBER_ID=your_phone_number_uuid_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here

# ElevenLabs
ELEVENLABS_API_KEY=xi-...

# Apify Lead Finder (F-010)
# App starts fine when disabled or when the token is missing.
APIFY_ENABLED=true
APIFY_API_TOKEN=your_apify_token_here
# Default Apify actor: Google Maps / Places scraper (best for industry+location+keyword B2B leads).
# Alternatives: apify/google-search-scraper, vdrmota~contact-info-scraper
APIFY_DEFAULT_ACTOR_ID=compass~crawler-google-places

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=86400000